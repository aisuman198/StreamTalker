{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src/main/**/*", "src/shared/**/*"],
  "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts", "src/test/**"]
}
